# Copy to .env.local for local development. Never commit real values —
# see .gitignore. On Vercel these are set in the project's Environment
# Variables settings, not committed here.

# Clerk (ADR 002). Publishable key is exposed to the client (VITE_ prefix
# required for Vite to inline it); secret key is server-only, used by
# api/_lib/auth.ts to verify session tokens.
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Postgres connection string for the sync API routes (api/sync/*.ts).
# Provisioned automatically when a Postgres/Neon integration is added via
# the Vercel Marketplace; pull locally with `vercel env pull`.
POSTGRES_URL=
