# MyScript iink REST API credentials.
# Get free developer keys at https://developer.myscript.com/
#
# Copy this file to `.env.local` and fill in your real values.
# Vite only exposes vars prefixed with VITE_ to the client.
#
# NOTE: These keys are exposed in the browser bundle. For production you should
# proxy MyScript calls through a backend so the application key/HMAC secret are
# never shipped to the client. See README "Going to production" for details.

VITE_MYSCRIPT_APP_KEY=your-application-key-here
VITE_MYSCRIPT_HMAC_KEY=your-hmac-key-here

# Optional override of the iink REST host (defaults to the public cloud).
VITE_MYSCRIPT_HOST=https://cloud.myscript.com
